# App security
WATCHOUT_TELEGRAM_SECRET_KEY=replace-with-a-long-random-secret
WATCHOUT_TELEGRAM_DEFAULT_ADMIN_USERNAME=admin
WATCHOUT_TELEGRAM_DEFAULT_ADMIN_PASSWORD=change-me-before-first-run

# Backend runtime
# Local host backend: postgresql+psycopg://watchout:watchout_dev_password@localhost:5432/watchout_telegram
# Docker backend: postgresql+psycopg://watchout:watchout_dev_password@postgres:5432/watchout_telegram
# SQLite demo mode: sqlite:///./data/app.db
WATCHOUT_TELEGRAM_DATABASE_URL=postgresql+psycopg://watchout:watchout_dev_password@localhost:5432/watchout_telegram
WATCHOUT_TELEGRAM_SESSION_DIR=./data/sessions
WATCHOUT_TELEGRAM_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Periodic backfill
WATCHOUT_TELEGRAM_ENABLE_SCHEDULER=true
WATCHOUT_TELEGRAM_BACKFILL_ENABLED=true
WATCHOUT_TELEGRAM_BACKFILL_INTERVAL_SECONDS=10800
WATCHOUT_TELEGRAM_BACKFILL_STARTUP_DELAY_SECONDS=120
WATCHOUT_TELEGRAM_BACKFILL_LIMIT_PER_TARGET=10000
WATCHOUT_TELEGRAM_BACKFILL_WINDOW_HOURS=4
WATCHOUT_TELEGRAM_LIVE_START_BACKFILL_LIMIT=10000
WATCHOUT_TELEGRAM_LIVE_START_BACKFILL_WINDOW_HOURS=4

# Docker ports
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE=

# PostgreSQL main database
POSTGRES_DB=watchout_telegram
POSTGRES_USER=watchout
POSTGRES_PASSWORD=watchout_dev_password
POSTGRES_PORT=5432

# Optional ClickHouse compose profile
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_PASSWORD=
